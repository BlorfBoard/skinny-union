---
// src/layouts/BaseLayout.astro
// Shared page shell: design tokens, masthead, footer.
// Every interior page (white paper, kit, press kit, etc.) wraps its
// content in this layout so the masthead/CSS live in exactly one place.
// Uses Astro's built-in class:list for the active-door nav highlight —
// no extra dependency needed.

interface Props {
  title: string;
  description?: string;
  activeDoor?: 'employees' | 'press' | 'research' | 'fund';
}

const { title, description = "The Skinny Union Project", activeDoor = 'research' } = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{title}</title>
<meta name="description" content={description}>
<link rel="preconnect" href="https://fonts.googleapis.com/">
<link rel="preconnect" href="https://fonts.gstatic.com/" crossorigin="">
<link href="https://fonts.googleapis.com/css2?family=EB+Garamond:ital,wght@0,400;0,500;0,600;1,400;1,500&family=Jost:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
/* ══════════════════════════════════════════════════════
   DESIGN TOKENS — DuBois Palette (per Phase 0 Design Specification)
══════════════════════════════════════════════════════ */
:root {
  --crimson:    #C01F2E;
  --cobalt:     #1B4E9B;
  --gold:       #CC9B1A;
  --cream:      #EDE3CF;
  --cream-dark: #E3D8C0;
  --ink:        #1A1A1A;
  --slate:      #7A8490;
  --rule:       #C4B99A;

  --garamond: 'EB Garamond', Georgia, serif;
  --jost:     'Jost', 'Helvetica Neue', Arial, sans-serif;

  --measure:  66ch;
  --space:    8px;
}

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
html { font-size: 18px; scroll-behavior: smooth; }
body {
  background: var(--cream);
  color: var(--ink);
  font-family: var(--garamond);
  font-size: 1rem;
  line-height: 1.62;
  -webkit-font-smoothing: antialiased;
}

/* ══════════════════════════════════════════════════════
   MASTHEAD (per Phase 0 Section I / VI — reused across interior pages)
══════════════════════════════════════════════════════ */
.masthead {
  background: var(--cream);
  border-bottom: 2px solid var(--ink);
  padding: 0 48px;
  position: sticky;
  top: 0;
  z-index: 10;
}
.masthead-inner {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  padding: 20px 0 16px;
  gap: 32px;
  flex-wrap: wrap;
}
.wordmark {
  font-family: var(--garamond);
  font-size: 2.2rem;
  font-weight: 400;
  letter-spacing: -0.01em;
  color: var(--ink);
  line-height: 1;
  flex-shrink: 0;
  text-decoration: none;
}
.wordmark span {
  display: block;
  font-family: var(--jost);
  font-size: 0.6rem;
  font-weight: 500;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: var(--slate);
  margin-bottom: 4px;
}
.nav { display: flex; gap: 40px; align-items: flex-start; flex-wrap: wrap; }
.nav-item { display: flex; flex-direction: column; gap: 3px; text-align: right; text-decoration: none; }
.nav-label {
  font-family: var(--jost);
  font-size: 0.72rem;
  font-weight: 500;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--cobalt);
}
.nav-item.nav-current .nav-label { color: var(--crimson); }
.nav-sub {
  font-family: var(--jost);
  font-size: 0.62rem;
  font-weight: 300;
  font-style: italic;
  color: var(--slate);
}
.nav-item.nav-suspended { opacity: 0.45; cursor: default; }
.nav-item.nav-suspended .nav-label { color: var(--slate); }

/* ══════════════════════════════════════════════════════
   DOCUMENT HERO — publication title block
══════════════════════════════════════════════════════ */
.pub-hero {
  padding: 64px 48px 48px;
  border-bottom: 1px solid var(--rule);
  position: relative;
}
.pub-hero::before {
  content: '';
  position: absolute;
  top: 0; left: 0;
  width: 6px;
  height: 100%;
  background: var(--cobalt);
}
.pub-hero-eyebrow {
  font-family: var(--jost);
  font-size: 0.68rem;
  font-weight: 500;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: var(--slate);
  margin-bottom: 20px;
  padding-left: 24px;
}
.pub-hero-headline {
  font-family: var(--garamond);
  font-size: clamp(2.2rem, 4.2vw, 3.4rem);
  font-weight: 400;
  line-height: 1.1;
  letter-spacing: -0.02em;
  color: var(--ink);
  max-width: 20ch;
  padding-left: 24px;
  margin-bottom: 20px;
}
.pub-hero-headline em { font-style: italic; color: var(--crimson); }
.pub-hero-rule { width: 80px; height: 3px; background: var(--cobalt); margin-left: 24px; margin-bottom: 20px; }
.pub-hero-sub {
  font-family: var(--garamond);
  font-size: 1.05rem;
  font-style: italic;
  color: var(--slate);
  max-width: 58ch;
  padding-left: 24px;
  line-height: 1.55;
}

/* ══════════════════════════════════════════════════════
   NOTICE BAND — canonical legal-foundation formulation
══════════════════════════════════════════════════════ */
.notice-band {
  background: var(--cream-dark);
  border-top: 1px solid var(--rule);
  border-bottom: 1px solid var(--rule);
  padding: 16px 48px;
  display: flex;
  align-items: center;
  gap: 16px;
}
.notice-band p {
  font-family: var(--garamond);
  font-size: 0.98rem;
  font-style: italic;
  color: var(--ink);
  max-width: var(--measure);
}

/* ══════════════════════════════════════════════════════
   PUBLICATION BODY — asymmetric grid, per section
══════════════════════════════════════════════════════ */
.pub-body { padding: 0 48px; max-width: 1180px; margin: 0 auto; }

.pub-section {
  display: grid;
  grid-template-columns: 220px 1fr;
  gap: 0 56px;
  border-bottom: 1px solid var(--rule);
  padding: 56px 0;
}
.pub-section-intro { padding-top: 48px; }

.col-structural { padding-top: 4px; position: sticky; top: 100px; align-self: start; }
.section-number {
  font-family: var(--jost);
  font-size: 0.6rem;
  font-weight: 500;
  letter-spacing: 0.22em;
  text-transform: uppercase;
  color: var(--rule);
  display: block;
  margin-bottom: 8px;
}
.section-title-label {
  font-family: var(--jost);
  font-size: 0.72rem;
  font-weight: 600;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--cobalt);
  display: block;
  line-height: 1.4;
}

.col-main h2 {
  font-family: var(--garamond);
  font-size: 1.9rem;
  font-weight: 400;
  letter-spacing: -0.01em;
  color: var(--ink);
  line-height: 1.2;
  margin-bottom: 20px;
  padding-bottom: 12px;
  border-bottom: 2px solid var(--cobalt);
}
.col-main p {
  font-family: var(--garamond);
  font-size: 1.05rem;
  line-height: 1.65;
  color: var(--ink);
  max-width: var(--measure);
  margin-bottom: 18px;
}
.col-main ul { max-width: var(--measure); margin: 0 0 18px 0; padding-left: 0; list-style: none; }
.col-main li { margin-bottom: 16px; padding-left: 24px; position: relative; line-height: 1.6; }
.col-main li::before { content: '\2014'; position: absolute; left: 0; color: var(--cobalt); }
.col-main em { font-style: italic; }
.col-main .token-emphasis {
  font-style: italic;
  color: var(--cobalt);
  border-bottom: 1px dotted var(--cobalt);
}

/* ══════════════════════════════════════════════════════
   BREAKOUT BOXES — pending-content state
══════════════════════════════════════════════════════ */
.pub-box {
  margin: 28px 0;
  padding: 20px 24px;
  background: var(--cream-dark);
  border-left: 4px solid var(--gold);
}
.pub-box-label {
  display: block;
  font-family: var(--jost);
  font-size: 0.62rem;
  font-weight: 600;
  letter-spacing: 0.16em;
  text-transform: uppercase;
  color: var(--gold);
  margin-bottom: 10px;
}
.pub-box-pending { border-left-color: var(--slate); }
.pub-box-pending-note {
  font-family: var(--garamond);
  font-size: 0.92rem;
  font-style: italic;
  color: var(--slate);
  line-height: 1.55;
}

/* ══════════════════════════════════════════════════════
   FOOTER
══════════════════════════════════════════════════════ */
.doc-footer {
  border-top: 2px solid var(--ink);
  padding: 28px 48px;
  display: flex;
  justify-content: space-between;
  align-items: center;
  flex-wrap: wrap;
  gap: 12px;
  max-width: 1180px;
  margin: 0 auto;
}
.footer-meta {
  font-family: var(--jost);
  font-size: 0.65rem;
  font-weight: 400;
  letter-spacing: 0.1em;
  color: var(--slate);
}
.footer-note {
  font-family: var(--garamond);
  font-size: 0.85rem;
  font-style: italic;
  color: var(--slate);
  max-width: 60ch;
}

@media (max-width: 780px) {
  .pub-section { grid-template-columns: 1fr; gap: 8px; }
  .col-structural { position: static; padding-top: 0; margin-bottom: 12px; }
  .masthead-inner { flex-direction: column; align-items: flex-start; gap: 12px; }
  .nav { gap: 24px; }
  .nav-item { text-align: left; }
}



/* ══════════════════════════════════════════════════════
   PULL QUOTES — asymmetric offset, alternating sides.
   Grid-based (never floated): the empty track is a deliberate
   margin note, not a wrap-overflow artifact — matches the
   Phase 0 asymmetric-grid ratio (structural : main :: 1 : 2).
══════════════════════════════════════════════════════ */
.pull-quote-row {
  display: grid;
  gap: 32px;
  margin: 4px 0 32px;
  align-items: start;
}
.pull-quote-row.pq-left  { grid-template-columns: 2fr 1fr; }
.pull-quote-row.pq-right { grid-template-columns: 1fr 2fr; }
.pq-left  .pull-quote { grid-column: 1; }
.pq-right .pull-quote { grid-column: 2; }

.pull-quote {
  font-family: var(--garamond);
  font-style: italic;
  font-weight: 400;
  font-size: 1.35rem;
  line-height: 1.4;
  color: var(--ink);
  padding: 4px 0 4px 22px;
  position: relative;
}
.pq-left .pull-quote  { border-left: 3px solid var(--crimson); }
.pq-right .pull-quote { border-left: 3px solid var(--cobalt); padding-left: 22px; }

.pq-mark {
  font-family: var(--garamond);
  font-style: normal;
  font-size: 2.6rem;
  line-height: 0;
  color: var(--gold);
  vertical-align: -14px;
  margin-right: 2px;
}

@media (max-width: 780px) {
  .pull-quote-row.pq-left,
  .pull-quote-row.pq-right { grid-template-columns: 1fr; }
  .pq-left .pull-quote, .pq-right .pull-quote { grid-column: 1; }
}

/* ══════════════════════════════════════════════════════
   BOX BREAKS — locked box fragments run full-width as a break
   in the main text, never float-overhang past section text
══════════════════════════════════════════════════════ */
.box-break {
  width: 100%;
  margin: 8px 0 32px;
}
.box-break > * { max-width: none !important; }

.box-technical-note {
  background: var(--cream-dark);
  border-left: 3px solid var(--gold);
  padding: 28px 32px;
  margin: 12px 0 28px;
  max-width: none;
}.box-technical-note .box-eyebrow {
  font-family: var(--jost);
  font-size: 0.58rem;
  font-weight: 500;
  letter-spacing: 0.16em;
  text-transform: uppercase;
  color: var(--gold);
  margin-bottom: 16px;
  display: block;
}.box-technical-note .box-title {
  font-family: var(--garamond);
  font-size: 1.05rem;
  font-style: italic;
  font-weight: 400;
  color: var(--ink);
  margin-bottom: 14px;
  line-height: 1.3;
}.box-technical-note .box-para {
  font-family: var(--garamond);
  font-size: 0.92rem;
  line-height: 1.55;
  color: var(--ink);
  margin-bottom: 12px;
}.box-technical-note .box-para:last-of-type {
  margin-bottom: 0;
}.box-technical-note a {
  color: var(--cobalt);
  text-decoration: underline;
  text-decoration-color: var(--rule);
  text-decoration-thickness: 1px;
  text-underline-offset: 2px;
}.box-technical-note a:hover {
  text-decoration-color: var(--cobalt);
}.box-technical-note .box-term-label {
  font-family: var(--jost);
  font-size: 0.62rem;
  font-weight: 600;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--cobalt);
  margin-bottom: 4px;
  display: block;
}.box-technical-note .box-caution {
  font-family: var(--garamond);
  font-style: italic;
  font-size: 0.86rem;
  color: var(--slate);
  margin-top: 14px;
  padding-top: 12px;
  border-top: 1px solid var(--rule);
}

@media (max-width: 680px) {.box-technical-note {
    max-width: 100%;
  }
}

.box-history-bundle {
  background: var(--cream-dark);
  border-left: 3px solid var(--gold);
  padding: 32px 40px;
  margin: 28px 0;
  max-width: none;
}.box-history-bundle .box-eyebrow {
  font-family: var(--jost);
  font-size: 0.58rem;
  font-weight: 500;
  letter-spacing: 0.16em;
  text-transform: uppercase;
  color: var(--gold);
  margin-bottom: 16px;
  display: block;
}.box-history-bundle .box-title {
  font-family: var(--garamond);
  font-size: 1.35rem;
  font-style: italic;
  font-weight: 400;
  color: var(--ink);
  margin-bottom: 18px;
  line-height: 1.3;
}.box-history-bundle .box-para {
  font-family: var(--garamond);
  font-size: 0.96rem;
  line-height: 1.6;
  color: var(--ink);
  margin-bottom: 14px;
}.box-history-bundle .box-para:last-child {
  margin-bottom: 0;
}.box-history-bundle a {
  color: var(--cobalt);
  text-decoration: underline;
  text-decoration-color: var(--rule);
  text-decoration-thickness: 1px;
  text-underline-offset: 2px;
}.box-history-bundle a:hover {
  text-decoration-color: var(--cobalt);
}

@media (max-width: 680px) {.box-history-bundle {
    max-width: 100%;
    padding: 24px 28px;
  }
}

.box-statutory-sampler {
  background: var(--cream-dark);
  border-left: 3px solid var(--gold);
  padding: 28px 32px;
  margin: 12px 0 28px;
  max-width: none;
}.box-statutory-sampler .box-eyebrow {
  font-family: var(--jost);
  font-size: 0.58rem;
  font-weight: 500;
  letter-spacing: 0.16em;
  text-transform: uppercase;
  color: var(--gold);
  margin-bottom: 20px;
  display: block;
}.box-statutory-sampler .box-entry {
  margin-bottom: 18px;
  padding-bottom: 16px;
  border-bottom: 1px solid var(--rule);
}.box-statutory-sampler .box-entry:last-child {
  margin-bottom: 0;
  padding-bottom: 0;
  border-bottom: none;
}.box-statutory-sampler .box-juris {
  font-family: var(--garamond);
  font-size: 1.05rem;
  font-style: italic;
  font-weight: 400;
  color: var(--ink);
  margin-bottom: 8px;
}.box-statutory-sampler .box-layer {
  font-family: var(--garamond);
  font-size: 0.92rem;
  line-height: 1.5;
  color: var(--ink);
  margin-bottom: 8px;
}.box-statutory-sampler .box-layer:last-child {
  margin-bottom: 0;
}.box-statutory-sampler .box-layer-label {
  font-family: var(--jost);
  font-size: 0.62rem;
  font-weight: 600;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--cobalt);
  margin-right: 8px;
}.box-statutory-sampler .box-layer-absent {
  font-style: italic;
  color: var(--slate);
}.box-statutory-sampler .box-layer a {
  color: var(--cobalt);
  text-decoration: underline;
  text-decoration-color: var(--rule);
  text-decoration-thickness: 1px;
  text-underline-offset: 2px;
}.box-statutory-sampler .box-layer a:hover {
  text-decoration-color: var(--cobalt);
}.box-statutory-sampler .box-caption {
  font-family: var(--garamond);
  font-style: italic;
  font-size: 0.82rem;
  line-height: 1.45;
  color: var(--slate);
  margin-top: 18px;
}

@media (max-width: 680px) {.box-statutory-sampler {
    max-width: 100%;
  }
}

.box-statutory-sampler .box-intro {
  font-family: var(--garamond);
  font-size: 0.95rem;
  line-height: 1.55;
  color: var(--ink);
  margin-bottom: 20px;
}
</style>
</head>
<body>

<header class="masthead">
  <div class="masthead-inner">
    <a href="/" class="wordmark">
      <span>The Skinny Union Project</span>
      Skinny Union
    </a>
    <nav class="nav">
      <a href="/employees/" class:list={["nav-item", { "nav-current": activeDoor === 'employees' }]}>
        <span class="nav-label">Employees</span>
        <span class="nav-sub">Get Paid</span>
      </a>
      <a href="/press/" class:list={["nav-item", { "nav-current": activeDoor === 'press' }]}>
        <span class="nav-label">Press</span>
        <span class="nav-sub">The Missing Story</span>
      </a>
      <a href="/research/" class:list={["nav-item", { "nav-current": activeDoor === 'research' }]}>
        <span class="nav-label">Research</span>
        <span class="nav-sub">Ooh, a White Paper!</span>
      </a>
      <span class="nav-item nav-suspended">
        <span class="nav-label">Fund</span>
        <span class="nav-sub">Suspended</span>
      </span>
    </nav>
  </div>
</header>

<slot />

<footer class="doc-footer">
  <p class="footer-meta">The Skinny Union Project &nbsp;&middot;&nbsp; White Paper &nbsp;&middot;&nbsp; Research Door</p>
  <p class="footer-note">The Skinny Union Project is not a proposal to weaken unions or undermine collective bargaining. It is a proposal to extend collective bargaining to workers and sectors that traditional union models have consistently failed to reach.</p>
</footer>

</body>
</html>
